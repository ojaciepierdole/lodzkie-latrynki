# Vercel Cron secret (zabezpieczenie endpointu /api/scrape)
CRON_SECRET=your-secret-here

# Opcjonalnie: Google Maps Geocoding API (fallback)
GOOGLE_GEOCODING_API_KEY=

# Vercel Blob token (auto na Vercel, wymagane lokalnie)
BLOB_READ_WRITE_TOKEN=

# Opcjonalnie: Sentry DSN
SENTRY_DSN=

# App URL
NEXT_PUBLIC_APP_URL=https://lodzkie-latrynki.vercel.app
